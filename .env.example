# ============================================================
# GRAVY REFERRAL PROGRAMME - ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# ============================================================

# --- Telegram Bot ---
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=YourBotUsername

# --- Web App URL ---
# The HTTPS URL where your Mini App frontend is hosted
# Must be HTTPS — Telegram requires it
WEBAPP_URL=https://your-domain.com

# --- Database ---
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/gravy_referral
DB_SSL=false

# --- Gravy Mobile API ---
# Used to verify user onboarding
GRAVY_API_BASE_URL=https://api.gravymobile.com
GRAVY_API_KEY=your_gravy_api_key_here

# --- Gravy Download Link ---
GRAVY_DOWNLOAD_URL=https://gravymobile.com/download

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Wallet Settings ---
MIN_WITHDRAWAL=500
